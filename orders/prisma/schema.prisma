datasource db {
  provider = "sqlite"
}

generator client {
  provider = "prisma-client-js"
}

model Order {
  id         String @id @default(uuid())
  userId     String
  items      OrderItem[]
}

model OrderItem {
  id        String @id @default(uuid())
  productId String
  orderId   String
  order     Order  @relation(fields: [orderId], references: [id])
}
